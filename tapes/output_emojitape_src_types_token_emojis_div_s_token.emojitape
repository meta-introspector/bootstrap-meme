Comment("RUST_CODE_BLOCK_UNPARSABLE:use crate::types::token::Token;\nuse std::collections::HashMap;\nuse std::iter::Peekable;\nuse std::slice::Iter;\n\npub const EMOJI: &str = \"➗\";\n\npub fn to_token() -> Token {\n    Token::DivS\n}\n\npub fn execute_div_s(\n    stack: &mut Vec<i32>,\n    _locals: &mut HashMap<i32, i32>,\n    _tokens_iter: &mut Peekable<Iter<Token>>,\n) -> Result<(), String> {\n    if stack.len() >= 2 {\n        let b = stack.pop().unwrap();\n        let a = stack.pop().unwrap();\n        if b == 0 {\n            return Err(\"Division by zero.\".to_string());\n        }\n        stack.push(a / b);\n        Ok(())\n    } else {\n        Err(\"Not enough operands for DivS operation.\".to_string())\n    }\n}")